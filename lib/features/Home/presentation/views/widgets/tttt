    Widget _imagePlaceholderSquare(double w, double h) {
      return Container(
        height: h,
        width: w,
        color: const Color(0xFFF3F4F6),
        child: Icon(
          Icons.home_outlined,
          size: 30.r,
          color: const Color(0xFF9CA3AF),
        ),
      );
